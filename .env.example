# ---------- Docker Compose project ----------
COMPOSE_PROJECT_NAME=base-ai

# ---------- MySQL: system database ----------
MYSQL_URL=jdbc:mysql://mysql.example.com:3306/base_ai_system?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=base_ai_system
MYSQL_PASSWORD=change-me

# ---------- PostgreSQL: subordinate business database ----------
POSTGRES_URL=jdbc:postgresql://postgres.example.com:5432/base_ai_business?currentSchema=public
POSTGRES_USERNAME=base_ai_business
POSTGRES_PASSWORD=change-me
POSTGRES_POOL_SIZE=10

# ---------- Redis: cache database ----------
REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DATABASE=0
REDIS_TIMEOUT=5s

# ---------- Platform branding and authentication ----------
APP_BRAND_CODE=ai-platform
APP_BRAND_NAME_EN=AI Platform
APP_BRAND_NAME_ZH=AI平台
APP_BRAND_SHORT_NAME=AI
APP_TOKEN_SECRET=replace-with-at-least-32-random-characters
APP_TOKEN_EXPIRE_MINUTES=720
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_PASSWORD=replace-before-first-start
APP_CONFIG_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# ---------- Internal service authentication ----------
PYTHON_WORKER_URL=http://python-worker:8000
PYTHON_WORKER_INTERNAL_TOKEN=replace-with-a-random-internal-token
JAVA_INSTANCE_ID=java-backend-1
PYTHON_WORKER_INSTANCE_ID=python-worker-1

# ---------- OpenAI-compatible LLM YAML ----------
AI_GROUP_POOLS_FILE=/etc/base-ai/ai-group-pools.yml
AI_FEATURES_FILE=/etc/base-ai/ai-features.yml
LLM_TIMEOUT_SECONDS=60
LLM_LOG_CONTENT=false

# ---------- Automation API trigger ----------
API_TRIGGER_ALLOWED_HOSTS=api.example.com,*.trusted.example.com
API_TRIGGER_ALLOW_PRIVATE_NETWORK=false
API_TRIGGER_SCHEDULER_POOL_SIZE=4
API_TRIGGER_LOCK_SECONDS=300
API_TRIGGER_RESULT_MAX_LENGTH=2000

# ---------- Unified task logging ----------
JOB_LOG_PERSIST_LEVEL=INFO
JOB_LOG_QUEUE_CAPACITY=10000
JOB_LOG_BATCH_SIZE=100
JOB_LOG_FLUSH_INTERVAL_MS=500
JOB_LOG_RETENTION_DAYS=7
JOB_HEARTBEAT_TIMEOUT_SECONDS=120

# ---------- Application ports ----------
BACKEND_PORT=8080
FRONTEND_PORT=80
FRONTEND_BACKEND_URL=http://backend:8080

# ---------- Optional image and package mirrors ----------
MAVEN_IMAGE=maven:3.9.9-eclipse-temurin-17
JRE_IMAGE=eclipse-temurin:17-jre
NODE_IMAGE=node:24-alpine
PYTHON_IMAGE=python:3.12-slim
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com
